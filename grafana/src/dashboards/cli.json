{
  "title": "CLI usage",
  "uid": "tuist-cli",
  "tags": ["tuist", "cli"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(tuist_cli_invocations_total, project)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "command",
        "label": "Command",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(tuist_cli_invocations_total{project=~\"$project\"}, command)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Invocations per minute by command",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (command) (rate(tuist_cli_invocations_total{project=~\"$project\",command=~\"$command\"}[5m])) * 60",
          "legendFormat": "{{command}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Invocation duration (p50/p95)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, command) (rate(tuist_cli_invocation_duration_seconds_bucket{project=~\"$project\",command=~\"$command\"}[5m])))",
          "legendFormat": "p50 {{command}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, command) (rate(tuist_cli_invocation_duration_seconds_bucket{project=~\"$project\",command=~\"$command\"}[5m])))",
          "legendFormat": "p95 {{command}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed invocations (last hour)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (command) (increase(tuist_cli_invocations_total{status=\"failure\",project=~\"$project\",command=~\"$command\"}[1h]))",
          "legendFormat": "{{command}}"
        }
      ],
      "options": { "graphMode": "area" }
    }
  ],
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
