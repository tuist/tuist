{
  "title": "Xcode build performance",
  "uid": "tuist-xcode-builds",
  "tags": ["tuist", "xcode", "builds"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(tuist_xcode_build_runs_total, project)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Build rate (per minute)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (project) (rate(tuist_xcode_build_runs_total{project=~\"$project\"}[5m])) * 60",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rpm" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Success rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (project) (rate(tuist_xcode_build_runs_total{status=\"success\",project=~\"$project\"}[5m])) / clamp_min(sum by (project) (rate(tuist_xcode_build_runs_total{project=~\"$project\"}[5m])), 1e-9)",
          "legendFormat": "{{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Build duration (p50/p95)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, project) (rate(tuist_xcode_build_run_duration_seconds_bucket{project=~\"$project\"}[5m])))",
          "legendFormat": "p50 {{project}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, project) (rate(tuist_xcode_build_run_duration_seconds_bucket{project=~\"$project\"}[5m])))",
          "legendFormat": "p95 {{project}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Top schemes by build volume",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (scheme) (increase(tuist_xcode_build_runs_total{project=~\"$project\"}[1h])))",
          "legendFormat": "{{scheme}}"
        }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Failing builds (last hour)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (project) (increase(tuist_xcode_build_runs_total{status!=\"success\",project=~\"$project\"}[1h]))",
          "legendFormat": "{{project}}"
        }
      ],
      "options": { "graphMode": "area", "colorMode": "value" }
    }
  ],
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
