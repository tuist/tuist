{
  "title": "Tuist Xcode",
  "uid": "tuist-xcode",
  "tags": [
    "tuist",
    "xcode"
  ],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(tuist_xcode_build_runs_total, project)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 200,
      "type": "row",
      "title": "Builds",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 201,
      "type": "stat",
      "title": "Total builds",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_build_runs_total{project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 202,
      "type": "stat",
      "title": "Build success rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(tuist_xcode_build_runs_total{status=\"success\",project=\"$project\"}[$__range])) / clamp_min(sum(increase(tuist_xcode_build_runs_total{project=\"$project\"}[$__range])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 203,
      "type": "stat",
      "title": "Failed builds",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_build_runs_total{status!=\"success\",project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 204,
      "type": "timeseries",
      "title": "Build duration",
      "description": "p50, p90, p99 and average build duration over time.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(tuist_xcode_build_run_duration_seconds_bucket{project=\"$project\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.9, sum by (le) (rate(tuist_xcode_build_run_duration_seconds_bucket{project=\"$project\"}[$__rate_interval])))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(tuist_xcode_build_run_duration_seconds_bucket{project=\"$project\"}[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "refId": "D",
          "expr": "sum(rate(tuist_xcode_build_run_duration_seconds_sum{project=\"$project\"}[$__rate_interval])) / clamp_min(sum(rate(tuist_xcode_build_run_duration_seconds_count{project=\"$project\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 205,
      "type": "bargauge",
      "title": "Top schemes by build volume",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (scheme) (round(increase(tuist_xcode_build_runs_total{project=\"$project\"}[$__range]))))",
          "legendFormat": "{{scheme}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Tests",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 301,
      "type": "stat",
      "title": "Total test runs",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_test_runs_total{project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 302,
      "type": "stat",
      "title": "Test case pass rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 8,
        "y": 24,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(tuist_xcode_test_cases_total{status=\"success\",project=\"$project\"}[$__range])) / clamp_min(sum(increase(tuist_xcode_test_cases_total{project=\"$project\"}[$__range])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 303,
      "type": "stat",
      "title": "Failed test cases",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 16,
        "y": 24,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_test_cases_total{status=\"failure\",project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 304,
      "type": "timeseries",
      "title": "Test run duration",
      "description": "p50, p90, p99 and average test run duration over time.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(tuist_xcode_test_run_duration_seconds_bucket{project=\"$project\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.9, sum by (le) (rate(tuist_xcode_test_run_duration_seconds_bucket{project=\"$project\"}[$__rate_interval])))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(tuist_xcode_test_run_duration_seconds_bucket{project=\"$project\"}[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "refId": "D",
          "expr": "sum(rate(tuist_xcode_test_run_duration_seconds_sum{project=\"$project\"}[$__rate_interval])) / clamp_min(sum(rate(tuist_xcode_test_run_duration_seconds_count{project=\"$project\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Xcode cache",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 401,
      "type": "stat",
      "title": "Hit rate",
      "description": "Remote + local hits divided by total cache events.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(tuist_xcode_cache_events_total{event_type=~\"local_hit|remote_hit\",project=\"$project\"}[$__range])) / clamp_min(sum(increase(tuist_xcode_cache_events_total{project=\"$project\"}[$__range])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 402,
      "type": "stat",
      "title": "Remote hits",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 6,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_cache_events_total{event_type=\"remote_hit\",project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 403,
      "type": "stat",
      "title": "Local hits",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_cache_events_total{event_type=\"local_hit\",project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 404,
      "type": "stat",
      "title": "Misses",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 18,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(tuist_xcode_cache_events_total{event_type=\"miss\",project=\"$project\"}[$__range])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 405,
      "type": "timeseries",
      "title": "Cache events over time",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event_type) (rate(tuist_xcode_cache_events_total{project=\"$project\"}[$__rate_interval])) * 60",
          "legendFormat": "{{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    }
  ]
}