<!-- Features section -->
<div class="marketing__home__section__features" data-last-clicked="1">
  <.home_feature
    index={1}
    title="start"
    banner_color={:violet}
    toggle_feature={
      JS.set_attribute({"data-last-clicked", "1"}, to: ".marketing__home__section__features")
    }
    collapsed={false}
    features={[
      gettext("Swift as a configuration language"),
      gettext("Zero-config setup. It just works™️"),
      gettext("Scales with your project")
    ]}
