</div>
<!-- Testimonials section -->
<div class="marketing__home__section__testimonials">
  <h2 class="font-xxl marketing__home__section__testimonials__title">
    {gettext("Users 💜 Tuist")}
  </h2>
  <div class="marketing__home__section__testimonials__main">
    <div
      :for={testimonials_column <- @testimonials}
      class="marketing__home__section__testimonials__column"
    >
      <div
        :for={testimonial <- testimonials_column}
        class="marketing__home__section__testimonials__testimonial"
      >
        <div class="marketing__home__section__testimonials__testimonial__header">
          <img
            src={testimonial.avatar_src}
            alt={testimonial.author}
            class="marketing__home__section__testimonials__testimonial__header__avatar"
          />
          <div class="marketing__home__section__testimonials__testimonial__author_info">
            <a
              class="font-m-strong marketing__home__section__testimonials__testimonial__author_info__name"
              target="_blank"
              href={testimonial.author_link}
            >
              {testimonial.author}
            </a>
            <div class="font-xs marketing__home__section__testimonials__testimonial__author_info__title">
              {testimonial.author_title}
            </div>
          </div>
        </div>
        <div class="font-xs marketing__home__section__testimonials__testimonial__body">
          {raw(testimonial.body)}
        </div>
      </div>
    </div>
  </div>
</div>
<!-- Time saved section -->
<div class="marketing__home__section__time_saved">
  <.marketing_shell class="marketing__home__section__time_saved__logo" />
  <h2 class="font-xxl marketing__home__section__time_saved__title">
    <span class="font-xxl-strong">{gettext("Millions")}</span>{gettext(" of minutes saved")}
  </h2>
  <.marketing_shell class="marketing__home__section__time_saved__logo" />
</div>
<!-- Highlights section -->
<% highlights = [
  %{
    title: "70%",
    subtitle: gettext("Faster builds"),
    cta_href: "/blog/2024/12/16/trendyol",
    cta_text: gettext("Read Trendyol's story"),
    cta_variant: "dark",
    cta_target: ""
  },
  %{
    title: gettext("Happier devs"),
    subtitle: gettext("We aim to empower developers to create great products."),
    cta_href: "https://medium.com/bumble-tech/scaling-ios-at-bumble-6f0602682903",
    cta_text: gettext("Read Bumble's story"),
    cta_variant: "light",
    cta_target: "_blank"
  },
  %{title: "7+", subtitle: gettext("Years building an OSS foundation")},
  %{title: "10K", subtitle: gettext("Teams using Tuist")},
  %{title: "300+", subtitle: gettext("Contributors")}
] %>

<div class="marketing__home__section__highlights">
  <.home_highlight_card
    :for={highlight <- highlights}
    title={highlight.title}
    subtitle={highlight.subtitle}
    cta_href={Map.get(highlight, :cta_href)}
    cta_text={Map.get(highlight, :cta_text)}
    cta_target={Map.get(highlight, :cta_target)}
    cta_variant={Map.get(highlight, :cta_variant)}
  />
</div>
<!-- Learn section -->
<div class="marketing__home__section__learn_more">
  <div class="marketing__home__section__learn_more__header">
    <h2 class="marketing__home__section__learn_more__header__title font-xxxl-strong">
      {gettext("Learn more")}
    </h2>
    <!-- TODO: Add link to all articles -->
    <.marketing_link class="marketing__home__section__learn_more__header__link">
      {gettext("View all")}
    </.marketing_link>
  </div>
  <div class="marketing__home__section__learn_more__body">
    <div class="marketing__home__section__learn_more__cards">
      <.more_card
        :for={post <- @read_more_posts}
        category={post.category}
        title={post.title}
        description={post.excerpt}
        href={post.slug}
        class="marketing__home__section__learn_more__cards__card"
      />
    </div>
  </div>
  <div class="marketing__home__section__learn_more__footer">
    <.marketing_link class="marketing__home__section__learn_more__footer__link" href={~p"/blog"}>
      {gettext("View all")}
    </.marketing_link>
  </div>
</div>
<!-- CTA section -->
<.cta />
