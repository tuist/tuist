<!-- Hero section -->
<div class="marketing__home__section__hero">
  <h1 class="font-xxxl-strong marketing__home__section__hero__title">
    {gettext("Scale your Swift App development")}
  </h1>
  <p class="marketing__home__section__hero__subtitle">
    {gettext(
      "We are an integrated and open core toolchain that extends Apple's official tools with insights, optimizations, and workflows to help you build better apps faster"
    )}
  </p>
  <.primary_button size="big" href="https://docs.tuist.io">
    {gettext("Get started")}
  </.primary_button>

  <div class="marketing__home__section__hero__terminal">
    <div class="marketing__home__section__hero__terminal__bar">
      <div class="marketing__home__section__hero__terminal__bar__close_button" />
      <div class="marketing__home__section__hero__terminal__bar__minimize_button" />
      <div class="marketing__home__section__hero__terminal__bar__maximize_button" />
    </div>
    <div class="marketing__home__section__hero__terminal__main">
      <div class="font-mono marketing__home__section__hero__terminal__main__prompt" id="termynal">
        <span data-ty="input" data-ty-prompt=">">tuist test</span>
        <span data-ty>
          <span class="marketing__home__section__hero__terminal__main__prompt__info">
            {gettext("INFO:")}
          </span>
          {gettext("Pulling cache binaries...")}
        </span>
        <span data-ty>
          <span class="marketing__home__section__hero__terminal__main__prompt__info">
            {gettext("INFO:")}
          </span>
          {gettext("You'll save 60% of compilation time")}
        </span>
        <span data-ty>
          <span class="marketing__home__section__hero__terminal__main__prompt__info">
            {gettext("INFO:")}
          </span>
          {gettext("Running tests - 4.200 tests skipped (already run)")}
        </span>
        <span data-ty="progress"></span>
        <span data-ty>
          <span class="marketing__home__section__hero__terminal__main__prompt__success">
            {gettext("SUCCESS:")}
          </span>
          {gettext("1250 tests ran successfully")}
        </span>
        <span data-ty>📝 {gettext("Report: https://tuist.dev/tuist/tuist/runs/589318")}</span>
      </div>
    </div>
  </div>
</div>
<!-- Companies section -->
