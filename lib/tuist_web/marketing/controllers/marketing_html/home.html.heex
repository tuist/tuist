    <:description>
      {gettext(
        "Create new, scalable projects with best industry practices and tools, or integrate them into your existing Xcode projects with ease, ensuring you're set up for success from the start."
      )}
    </:description>
    <:illustration>
      <svg
        width="960"
        height="400"
        viewBox="0 0 960 400"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M0 46.9928C0 42.0262 4.02623 38 8.99284 38H617.007C621.974 38 626 42.0262 626 46.9928V353.007C626 357.974 621.974 362 617.007 362H8.99287C4.02627 362 0 357.974 0 353.007V46.9928Z"
