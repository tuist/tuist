<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csp-nonce" content={get_csp_nonce()} />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title>
      {assigns[:head_title] || "Tuist"}
    </.live_title>
    <TuistWeb.LayoutComponents.head_meta_meta_tags {assigns} />
    <TuistWeb.LayoutComponents.head_x_meta_tags {assigns} />
    <script
      :for={
        structured_data <-
          TuistWeb.Marketing.StructuredMarkup.get_json_serialized_structured_data(assigns)
      }
      nonce={get_csp_nonce()}
      type="application/ld+json"
    >
      <%= raw structured_data %>
    </script>
    <!-- Import Maps -->
    <script type="importmap" nonce={get_csp_nonce()}>
      {
        "imports": {
          "phoenix_html": "https://cdn.jsdelivr.net/npm/phoenix_html@4.1.1/+esm",
          "phoenix": "https://cdn.jsdelivr.net/npm/phoenix@1.7.14/+esm",
          "phoenix_live_view": "https://cdn.jsdelivr.net/npm/phoenix_live_view@1.0.0/+esm"
        }
      }
    </script>
    <!-- Assets -->
    <link phx-track-static rel="stylesheet" href={~p"/marketing/css/marketing.css"} />
    <script defer phx-track-static type="module" src={~p"/marketing/js/marketing.js"}>
    </script>
    <!-- RSS -->
    <%= if assigns[:head_include_blog_rss_and_atom] do %>
      <link
        rel="alternate"
        type="application/rss+xml"
        title={gettext("Tuist Blog")}
        href={~p"/blog/rss.xml"}
      />
      <link
        rel="alternate"
        type="application/atom+xml"
        title={gettext("Tuist Blog")}
        href={~p"/blog/atom.xml"}
      />
    <% end %>

    <%= if assigns[:head_include_changelog_rss_and_atom] do %>
      <link
        rel="alternate"
        type="application/rss+xml"
        title={gettext("Tuist Changelog")}
        href={~p"/changelog/rss.xml"}
      />
      <link
        rel="alternate"
        type="application/atom+xml"
        title={gettext("Tuist Changelog")}
        href={~p"/changelog/atom.xml"}
      />
    <% end %>
    <%= if assigns[:head_include_newsletter_rss_and_atom] do %>
      <link
        rel="alternate"
        type="application/rss+xml"
        title={gettext("Swift Stories Newsletter")}
        href={~p"/newsletter/rss.xml"}
      />
      <link
        rel="alternate"
        type="application/atom+xml"
        title={gettext("Swift Stories Newsletter")}
        href={~p"/newsletter/atom.xml"}
      />
    <% end %>
    
<!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />

    <TuistWeb.LayoutComponents.head_analytics_scripts {assigns} />
    <!-- hCaptcha -->
    <script nonce={get_csp_nonce()} src="https://js.hcaptcha.com/1/api.js" async defer>
    </script>
    <!-- Chat box -->
    <script nonce={get_csp_nonce()}>
      (function(d,t) {
        var BASE_URL="https://app.chatwoot.com";
        var g=d.createElement(t),s=d.getElementsByTagName(t)[0];
        g.src=BASE_URL+"/packs/js/sdk.js";
        g.defer = true;
        g.async = true;
        s.parentNode.insertBefore(g,s);
        g.onload=function(){
          window.chatwootSDK.run({
            websiteToken: 'CuDUmBD5kcMEB26o8w4CJuTJ',
            baseUrl: BASE_URL
          })
        }
      })(document,"script");
    </script>
    <link rel="canonical" href={Tuist.Environment.app_url(path: @current_path)} />
  </head>
  <body data-scrollable="true">
    <TuistWeb.Marketing.MarketingLayoutComponents.header current_path={@current_path} {assigns} />
    {@inner_content}
    <TuistWeb.Marketing.MarketingLayoutComponents.footer />

    <div class="marketing__component__cookies" id="cookies-banner" phx-hook="CookiesBanner">
      <div class="marketing__component__cookies__logo">
        🍪
      </div>
      <div class="marketing__component__cookies__content">
        <div class="marketing__component__cookies__content__body" src="">
          <p class="marketing__component__cookies__content__body__title">
            {gettext("We use cookies")}
          </p>
          <p class="marketing__component__cookies__content__body__description">
            {raw(
              gettext(
                "This site uses cookies. By continuing to use our site, you agree to %{use_of_cookies}.",
                use_of_cookies: "<a href=\"#{~p"/cookies"}\">#{gettext("use of cookies")}</a>"
              )
            )}
          </p>
        </div>

        <TuistWeb.Marketing.MarketingLayoutComponents.primary_button
          size="medium"
          class="marketing__component__cookies__content__button"
          phx-click={JS.dispatch("accept-cookies")}
        >
          {gettext("Accept")}
        </TuistWeb.Marketing.MarketingLayoutComponents.primary_button>
      </div>
    </div>
  </body>
</html>
