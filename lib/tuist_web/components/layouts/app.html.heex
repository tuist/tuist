<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title>
      <%= assigns[:head_title] || "Tuist" %>
    </.live_title>
    <TuistWeb.LayoutComponents.head_meta_meta_tags {assigns} />
    <TuistWeb.LayoutComponents.head_x_meta_tags {assigns} />
    <!-- Assets -->
    <link phx-track-static rel="stylesheet" href={~p"/css/app.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/account_projects.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/auth.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/account_billing.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/project_analytics.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/project_run_detail.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/project_runs.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/project_tests.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/preview.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/app/pages/previews.css"} />
    <script defer phx-track-static type="module" src={~p"/assets/app.js"}>
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/js/Chart.js"}>
    </script>
    <script>
      function cssvar(name) {
        return getComputedStyle(document.documentElement).getPropertyValue(name);
      }
    </script>
    <TuistWeb.LayoutComponents.head_analytics_scripts {assigns} />
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
