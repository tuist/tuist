load("@rules_cc//cc:defs.bzl", "cc_library")

# Lua 5.4 compiled from the sources vendored in the `lua-src` crate (the same
# sources mlua's `vendored` feature would build via cargo). We build it as a
# first-class cc_library and link it into mlua-sys, instead of relying on
# lua-src's build script, which resolves its source dir from a compile-time
# env!("CARGO_MANIFEST_DIR") that does not survive Bazel sandboxing.
#
# The platform define matches lua-src's own per-OS build: LUA_USE_LINUX on Linux,
# LUA_USE_MACOSX on macOS (both enable LUA_USE_POSIX + LUA_USE_DLOPEN). dlopen needs
# -ldl at the final link on Linux; on macOS it lives in libSystem. lua.c/luac.c (the
# standalone interpreter/compiler mains) are not shipped by lua-src, so the glob is
# exactly the embeddable library.
# The lua-src crate repo is only visible by its canonical name from this (main)
# repo; the filegroups are defined via crate.annotation in //:MODULE.bazel.
#
# The label encodes the lua-src version (crates__lua-src-<version>), so a lua-src bump means
# updating it in both srcs and hdrs below (and the lua-5.4.* glob in MODULE.bazel). `mise run
# bazel-repin [check]` resolves this target, so a stale label fails fast in that guard.
cc_library(
    name = "lua",
    srcs = ["@@rules_rust++crate+crates__lua-src-550.0.0//:lua_c_srcs"],
    hdrs = ["@@rules_rust++crate+crates__lua-src-550.0.0//:lua_hdrs"],
    linkopts = select({
        "@platforms//os:linux": ["-ldl"],
        "//conditions:default": [],
    }),
    local_defines = select({
        "@platforms//os:linux": ["LUA_USE_LINUX"],
        "@platforms//os:macos": ["LUA_USE_MACOSX"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
