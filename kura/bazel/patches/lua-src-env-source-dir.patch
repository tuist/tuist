Make lua-src locate its vendored Lua sources from an injected anchor.

Upstream lua-src resolves the Lua source directory from
`env!("CARGO_MANIFEST_DIR")`, which is a *compile-time* macro. Under Bazel that
bakes the absolute path of the (sandboxed, later deleted) compile action, so when
the mlua-sys build script runs the directory no longer exists.

This patch lets Bazel inject `MLUA_LUA_SRC_ANCHOR` — the path of a file staged
inside the Lua source dir — and derives the source dir from its parent. Plain
`cargo` builds (env unset) keep the original behavior.
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -106,8 +106,15 @@
     pub fn try_build(&self, version: Version) -> Result<Artifacts, Box<dyn Error>> {
         let target = self.target.as_ref().ok_or("TARGET is not set")?;
         let out_dir = self.out_dir.as_ref().ok_or("OUT_DIR is not set")?;
-        let manifest_dir = Path::new(env!("CARGO_MANIFEST_DIR"));
-        let mut source_dir = manifest_dir.join(version.source_dir());
+        // Patched for Bazel: prefer an injected anchor over the compile-time
+        // CARGO_MANIFEST_DIR, which points at a deleted compile sandbox at runtime.
+        let mut source_dir = match env::var_os("MLUA_LUA_SRC_ANCHOR") {
+            Some(anchor) => Path::new(&anchor)
+                .parent()
+                .expect("MLUA_LUA_SRC_ANCHOR must point to a file inside the Lua source dir")
+                .to_path_buf(),
+            None => Path::new(env!("CARGO_MANIFEST_DIR")).join(version.source_dir()),
+        };
         let lib_dir = out_dir.join("lib");
         let include_dir = out_dir.join("include");

