{
  "name": "kura-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Localized Eleventy marketing site for Kura.",
  "scripts": {
    "build": "eleventy",
    "dev": "eleventy --serve --quiet",
    "clean": "rm -rf _site",
    "social:images": "node scripts/generate-social-images.mjs",
    "deploy": "eleventy && wrangler pages deploy _site --project-name kura --branch main"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "gray-matter": "^4.0.3",
    "sharp": "^0.34.5"
  },
  "aube": {
    "allowBuilds": {
      "sharp": true
    }
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.2.4",
    "@img/sharp-linux-x64": "0.34.5"
  }
}
