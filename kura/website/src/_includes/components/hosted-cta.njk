<section class="kura-section" data-variant="hosted">
  <div class="kura-container">
    <div class="kura-cta">
      <div data-part="body">
        <p data-part="eyebrow">{{ copy.home.hosted.eyebrow[locale.code] }}</p>
        <h2 data-part="title">{{ copy.home.hosted.title[locale.code] }}</h2>
        <p data-part="copy">{{ copy.home.hosted.body[locale.code] }}</p>
      </div>
      <a data-part="action" href="{{ site.tuist }}">
        <span>{{ copy.home.hosted.cta[locale.code] }}</span>
        <svg data-part="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>
