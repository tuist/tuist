---
permalink: "/blog/feed.xml"
eleventyExcludeFromCollections: true
---
{% set localizedPosts = collections.posts | filterByLocale("en") %}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ locales.en.labels.feedTitle }}</title>
  <subtitle>{{ locales.en.labels.feedDescription }}</subtitle>
  <link href="{{ site.url }}/blog/feed.xml" rel="self" />
  <link href="{{ site.url }}/blog/" />
  <id>{{ site.url }}/blog/</id>
  {% if localizedPosts[0] %}<updated>{{ localizedPosts[0].date | dateToRfc3339 }}</updated>{% endif %}
  <author>
    <name>{{ site.author }}</name>
  </author>
  {% for post in localizedPosts %}
    <entry>
      <title>{{ post.data.title }}</title>
      <link href="{{ site.url }}{{ post.url }}" />
      <id>{{ site.url }}{{ post.url }}</id>
      <updated>{{ post.date | dateToRfc3339 }}</updated>
      <published>{{ post.date | dateToRfc3339 }}</published>
      <summary>{{ post.data.description }}</summary>
      <content type="html"><![CDATA[{{ post.templateContent | safe }}]]></content>
    </entry>
  {% endfor %}
</feed>

