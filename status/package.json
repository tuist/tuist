{
  "name": "@tuist/status",
  "version": "0.1.0",
  "description": "Tuist public status page (Cloudflare Worker + Hono) backed by Grafana IRM",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "feed": "^4.2.2",
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "prettier": "^3.7.4",
    "typescript": "^5.6.3",
    "vitest": "^4.0.0",
    "wrangler": "^4.40.3"
  },
  "aube": {
    "allowBuilds": {
      "esbuild": true,
      "workerd": true,
      "sharp": false
    }
  }
}
