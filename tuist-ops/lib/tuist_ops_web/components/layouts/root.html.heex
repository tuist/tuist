<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{assigns[:page_title] || "Tuist Ops"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
    />
    <link rel="stylesheet" href={~p"/assets/noora.css"} />
    <style>
      html, body { margin: 0; height: 100%; }
      body {
        background: var(--noora-surface-background-primary);
        color: var(--noora-surface-label-primary);
        font-family: Inter, -apple-system, system-ui, sans-serif;
      }
      .layout { display: flex; flex-direction: column; min-height: 100vh; }
      .headerbar {
        display: flex; flex-shrink: 0; align-items: center;
        background: var(--noora-surface-background-tertiary);
        padding: var(--noora-spacing-6);
        border-bottom: 1px solid var(--noora-content-divider-line);
      }
      .headerbar [data-part="left-section"] {
        display: flex; flex-grow: 1; align-items: center; gap: var(--noora-spacing-5);
      }
      .headerbar [data-part="title"] {
        color: var(--noora-surface-label-primary);
        font: var(--noora-font-weight-medium) var(--noora-font-heading-medium);
      }
      .headerbar__logo { display: block; width: 32px; height: 32px; }
      .layout__main {
        display: flex; flex: 1; flex-direction: row;
        background: var(--noora-surface-background-primary);
      }
      .layout__main .noora-sidebar {
        position: sticky; top: 0; flex-shrink: 0; align-self: stretch;
        background: var(--noora-surface-background-primary);
        border-right: 1px solid var(--noora-content-divider-line);
        max-height: 100vh; overflow-y: auto;
      }
      .layout__content { flex: 1; min-width: 0; }
      .layout__content--muted { background: var(--noora-surface-background-tertiary); }
      .ops-content { padding: 28px 32px; }
      .ops-page__header { margin: 0 0 22px; }
      .ops-page__title {
        font-size: 20px; font-weight: 600; margin: 0;
        color: var(--noora-surface-label-primary);
      }
      .ops-page__subtitle {
        color: var(--noora-surface-label-secondary); font-size: 14px; margin: 5px 0 0;
      }
      .ops-stack { display: flex; flex-direction: column; gap: 24px; }
      .ops-tabpanel { margin-top: 20px; }
      .ops-section__title {
        font-size: 15px; font-weight: 600; margin: 0 0 12px;
        display: flex; align-items: center; gap: 8px;
        color: var(--noora-surface-label-primary);
      }
      .ops-centered { max-width: 560px; margin: 40px auto 0; }
      .ops-centered .ops-page__header { text-align: center; }
      .ops-form { display: flex; flex-direction: column; gap: 16px; margin-top: 4px; }
      .ops-form__actions { display: flex; gap: 10px; }
      .ops-field { display: flex; flex-direction: column; gap: var(--noora-spacing-3); }
      .ops-field__label {
        color: var(--noora-surface-label-primary);
        font: var(--noora-font-weight-medium) var(--noora-font-body-medium);
      }
      .ops-field__control {
        box-shadow: var(--noora-border-light-default); border: none;
        border-radius: var(--noora-radius-3);
        background: var(--noora-surface-background-primary);
        color: var(--noora-surface-label-primary); font: var(--noora-font-body-medium);
        padding: var(--noora-spacing-3) var(--noora-spacing-4);
        cursor: pointer; outline: none;
      }
      .ops-muted { margin: 0 0 4px; color: var(--noora-surface-label-secondary); font-size: 14px; }
      .ops-hint { margin: 12px 0 0; color: var(--noora-surface-label-tertiary); font-size: 14px; }
    </style>
    <script type="module">
      import Noora from "/assets/noora.js";
      const Hooks = (Noora && Noora.Hooks) || Noora || {};
      const noop = () => {};
      for (const el of document.querySelectorAll("[phx-hook]")) {
        const def = Hooks[el.getAttribute("phx-hook")];
        if (def && typeof def.mounted === "function") {
          const view = Object.assign(Object.create(def), {
            el, pushEvent: noop, pushEventTo: noop, handleEvent: noop,
          });
          try { view.mounted(); } catch (e) { console.error("noora hook failed", el, e); }
        }
      }
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
