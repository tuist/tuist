      "initial_version": "0.0.0",
      "include_paths": [
        "cli/**/*",
        ".xcode-version-releases",
        "Package.swift",
        "Package.resolved"
      ]
    },
    {
      "name": "app",
      "tag_prefix": "app@",
      "tag_regex": "^app@[0-9]+\\.[0-9]+\\.[0-9]+$",
