#!/usr/bin/env bash

set -euo pipefail

# This script is responsible for running the migrations in a world where
# we have migrations in Rails and migrations in Phoenix. Eventually, we'll
# be able to get rid of this script and use an schema as a starting point for
# Phoenix migrations. However, since we have on-premise customers, we need
# to make sure that they can transition from Rails-managed migrations to
# Phoenix-managed migrations.
#
# The logic of the script goes as follows:
# - 1. If there are Rails migrations to run. It runs them
# - 2. Then it adapts the schema to start running Phoenix migration
# - 3. Then runs the Phoenix migrations


BIN_DIR=$(dirname "$(readlink -f "$0")")

MIX_ENV=${MIX_ENV:-dev}

case "$MIX_ENV" in
  dev)
    DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/tuistcloud_development"
    ;;
esac

if [ -z "$DATABASE_URL" ]; then
  echo "DATABASE_URL is not set. Please ensure the MIX_ENV variable is correctly set."
  exit 1
fi


# A function that checks the database pointed at by DATABASE_URL has a table
table_exists() {
    local table=$1
    psql -d "$DATABASE_URL" -tAc "SELECT 1 FROM information_schema.tables WHERE table_name = '$table'" | grep -q 1
}

# A function that checks whether a database has a specific column in a table
ecto_specific_check() {
    psql -d "$DATABASE_URL" -tAc "SELECT 1 FROM information_schema.columns WHERE table_name = 'schema_migrations' AND column_name = 'inserted_at'" | grep -q 1
}

MIGRATION_PHASE="unknown"

if ! table_exists "schema_migrations"; then
    echo "The database is empty"
    MIGRATION_PHASE="empty"
elif table_exists "schema_migrations" && ! ecto_specific_check; then
    echo "The database is currently ActiveRecord-managed"
    MIGRATION_PHASE="active-record-managed"
elif table_exists "schema_migrations" && ecto_specific_check; then
    echo "The databae is currently Ecto-managed"
    MIGRATION_PHASE="ecto-managed"
fi

if [ "$MIGRATION_PHASE" = "active-record-managed" ]; then
  echo "Migrating using ActiveRecord..."
  $BIN_DIR/rails db:prepare

  echo "Adapting migrations table to use Ecto going forward..."
  # Since we no longer need information about the Rails migrations
  # we can delete all the rows in the table, adapt the schema to the Ecto schema
  # and then run the migrations using Ecto.
  #
  # Schema changes:
  #  - The version column is changed from varchar to int8
  #  - The inserted_at column is added
  psql -d "$DATABASE_URL" -c "DELETE FROM schema_migrations;"
  psql -d "$DATABASE_URL" -c "ALTER TABLE schema_migrations ADD COLUMN inserted_at TIMESTAMP WITHOUT TIME ZONE;"
  psql -d "$DATABASE_URL" -c "ALTER TABLE schema_migrations ALTER COLUMN version TYPE BIGINT USING version::BIGINT;"
elif [ "$MIGRATION_PHASE" = "empty" ]; then
  psql -d "$DATABASE_URL" -f $BIN_DIR/../phx/priv/repo/structure.sql
fi

echo "Executing the Ecto migrations..."
if [ "$MIX_ENV" = "dev" ]; then
  (cd $BIN_DIR/../phx && mix ecto.migrate)
else
  $BIN_DIR/../phx/bin/migrate
fi
