msgstr "チャンネル選択の保存に失敗しました。もう一度お試しください。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:242
#, elixir-autogen, elixir-format
msgid "Project not found. Please try again."
msgstr "プロジェクトが見つかりません。もう一度お試しください。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:174
#, elixir-autogen, elixir-format
msgid "Alert rule not found. Please try again."
msgstr "アラートルールが見つかりません。もう一度お試しください。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:89
#, elixir-autogen, elixir-format
msgid "Authorization request expired. Please start the Slack connection process again."
msgstr "認証リクエストの有効期限が切れました。Slack連携を再度開始してください。"
