msgstr "認証リクエストが無効です。もう一度お試しください。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:144
#: lib/tuist_web/controllers/slack_oauth_controller.ex:162
#: lib/tuist_web/controllers/slack_oauth_controller.ex:178
#: lib/tuist_web/controllers/slack_oauth_controller.ex:196
#: lib/tuist_web/controllers/slack_oauth_controller.ex:210
#, elixir-autogen, elixir-format
msgid "Slack authorization failed: %{reason}"
msgstr "Slack認証に失敗しました: %{reason}"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:182
#, elixir-autogen, elixir-format
