#: lib/tuist_web/controllers/slack_oauth_controller.ex:47
#, elixir-autogen, elixir-format
msgid "Invalid Slack authorization. Please try again."
msgstr "Slack 授權無效。請再試一次。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:81
#, elixir-autogen, elixir-format
msgid "Invalid authorization request. Please try again."
msgstr "授權請求無效。請再試一次。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:128
#: lib/tuist_web/controllers/slack_oauth_controller.ex:167
#, elixir-autogen, elixir-format
msgid "Slack authorization failed: %{reason}"
msgstr "Slack 授權失敗：%{reason}"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:132
#, elixir-autogen, elixir-format
msgid "Failed to save channel selection. Please try again."
msgstr "儲存頻道選擇失敗。請再試一次。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:194
#, elixir-autogen, elixir-format
msgid "Project not found. Please try again."
msgstr "找不到專案。請再試一次。"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:124
#, elixir-autogen, elixir-format
