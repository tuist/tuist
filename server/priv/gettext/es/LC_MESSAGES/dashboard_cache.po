msgstr "Aciertos en caché"

#: lib/tuist_web/live/module_cache_live.html.heex:195
#, elixir-autogen, elixir-format
msgid "Cache hits represents the total count of targets that were resolved from cache (local or remote) during the given period."
msgstr "Los aciertos en caché representan el recuento total de objetivos que se resolvieron desde la caché (local o remota) durante el período indicado."

#: lib/tuist_web/live/module_cache_live.ex:258
#, elixir-autogen, elixir-format
msgid "Cache misses"
msgstr "Fallos en caché"

#: lib/tuist_web/live/module_cache_live.html.heex:219
#, elixir-autogen, elixir-format
msgid "Cache misses represents the total count of cacheable targets that had to be rebuilt because they were not found in cache during the given period."
msgstr "Los fallos en caché representan el recuento total de objetivos cacheables que tuvieron que ser reconstruidos porque no se encontraron en caché durante el período indicado."

