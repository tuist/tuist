#: lib/tuist_web/live/module_cache_live.html.heex:195
#, elixir-autogen, elixir-format
msgid "Cache hits represents the total count of targets that were resolved from cache (local or remote) during the given period."
msgstr "Los aciertos de caché representan el recuento total de objetivos que se resolvieron desde la caché (local o remota) durante el período dado."

#: lib/tuist_web/live/module_cache_live.ex:286
#, elixir-autogen, elixir-format
msgid "Cache misses"
msgstr "Fallos de caché"

#: lib/tuist_web/live/module_cache_live.html.heex:215
#, elixir-autogen, elixir-format
msgid "Cache misses represents the total count of cacheable targets that had to be rebuilt because they were not found in cache during the given period."
msgstr "Los fallos de caché representan el recuento total de objetivos cacheables que tuvieron que ser recompilados porque no se encontraron en la caché durante el período dado."

