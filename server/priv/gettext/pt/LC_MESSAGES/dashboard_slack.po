msgstr "Conta não encontrada. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:148
#, elixir-autogen, elixir-format
msgid "Failed to save Slack installation. Please try again."
msgstr "Falha ao salvar a instalação do Slack. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:47
#, elixir-autogen, elixir-format
msgid "Invalid Slack authorization. Please try again."
msgstr "Autorização do Slack inválida. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:97
#, elixir-autogen, elixir-format
msgid "Invalid authorization request. Please try again."
msgstr "Solicitação de autorização inválida. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:144
#: lib/tuist_web/controllers/slack_oauth_controller.ex:162
#: lib/tuist_web/controllers/slack_oauth_controller.ex:178
#: lib/tuist_web/controllers/slack_oauth_controller.ex:196
#: lib/tuist_web/controllers/slack_oauth_controller.ex:210
#, elixir-autogen, elixir-format
msgid "Slack authorization failed: %{reason}"
msgstr "Falha na autorização do Slack: %{reason}"

#: lib/tuist_web/controllers/slack_oauth_controller.ex:182
#, elixir-autogen, elixir-format
msgid "Failed to save channel selection. Please try again."
msgstr "Falha ao salvar a seleção do canal. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:242
#, elixir-autogen, elixir-format
msgid "Project not found. Please try again."
msgstr "Projeto não encontrado. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:174
#, elixir-autogen, elixir-format
msgid "Alert rule not found. Please try again."
msgstr "Regra de alerta não encontrada. Por favor, tente novamente."

#: lib/tuist_web/controllers/slack_oauth_controller.ex:89
#, elixir-autogen, elixir-format
msgid "Authorization request expired. Please start the Slack connection process again."
msgstr "Solicitação de autorização expirada. Por favor, inicie o processo de conexão do Slack novamente."
