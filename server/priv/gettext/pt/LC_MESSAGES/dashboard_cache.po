#: lib/tuist_web/live/module_cache_live.html.heex:115
#, elixir-autogen, elixir-format
msgid "Cache hit rate represents the percentage of cacheable targets that were resolved from cache (local or remote) rather than being rebuilt."
msgstr "A taxa de acerto no cache representa a porcentagem de alvos cacheáveis que foram resolvidos a partir do cache (local ou remoto) em vez de serem recompilados."

#: lib/tuist_web/live/xcode_cache_live.html.heex:113
#, elixir-autogen, elixir-format
msgid "Cache hit rate represents the percentage of cacheable tasks that were resolved from cache (local or remote) rather than being rebuilt."
msgstr "A taxa de acerto no cache representa a porcentagem de tarefas cacheáveis que foram resolvidas a partir do cache (local ou remoto) em vez de serem recompiladas."

#: lib/tuist_web/live/module_cache_live.ex:238
#, elixir-autogen, elixir-format
msgid "Cache hits"
msgstr "Acertos no cache"

#: lib/tuist_web/live/module_cache_live.html.heex:195
#, elixir-autogen, elixir-format
msgid "Cache hits represents the total count of targets that were resolved from cache (local or remote) during the given period."
msgstr "Acertos no cache representam o número total de alvos que foram resolvidos a partir do cache (local ou remoto) durante o período informado."

#: lib/tuist_web/live/module_cache_live.ex:247
#, elixir-autogen, elixir-format
msgid "Cache misses"
msgstr "Faltas no cache"

#: lib/tuist_web/live/module_cache_live.html.heex:219
#, elixir-autogen, elixir-format
msgid "Cache misses represents the total count of cacheable targets that had to be rebuilt because they were not found in cache during the given period."
msgstr "Faltas no cache representam a contagem total de alvos cacheáveis que tiveram que ser recompilados porque não foram encontrados no cache durante o período informado."

#: lib/tuist_web/live/xcode_cache_live.ex:161
