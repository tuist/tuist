# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
hello-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/
/priv/static/app/assets/
/priv/static/marketing/assets/
/priv/static/docs/assets/
/priv/docs/images/og/
# Generated OG images for marketing pages (produced at build time via mix marketing.gen.og_images)
# Blog and newsletter images are kept in git since they are English-only and static.
/priv/static/marketing/images/og/generated/*.jpg
/priv/static/marketing/images/og/generated/ko/
/priv/static/marketing/images/og/generated/ru/
/priv/static/marketing/images/og/generated/ja/
/priv/static/marketing/images/og/generated/changelog/
/priv/static/apidocs/assets/
/priv/static/storybook/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/
node_modules/

.DS_Store
priv/secrets/*.key

.elixir_ls/
~/.pnpm/store

# ClickHouse
metadata
store
data
metadata_dropped
status
preprocessed_configs
uuid
clickhouse-data
config.d

# Local development
.opencode/
.claude/
minio/
