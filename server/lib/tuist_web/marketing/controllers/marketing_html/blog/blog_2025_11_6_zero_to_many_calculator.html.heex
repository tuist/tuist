<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <style>
      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      body {
        background: transparent;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }

      .calculator-container {
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
        padding: 0;
      }

      .input-group {
        margin-bottom: var(--noora-spacing-6);
      }

      .input-label {
        display: block;
        font-size: 14px;
        font-weight: 500;
        color: var(--noora-surface-label-primary, #111827);
        margin-bottom: var(--noora-spacing-3);
      }

      .input-hint {
        font-size: 11px;
        color: var(--noora-surface-label-tertiary, #9ca3af);
        margin-top: var(--noora-spacing-2);
      }

      input[type="range"] {
        width: 100%;
        padding: 0;
        height: 4px;
        -webkit-appearance: none;
        appearance: none;
        background: var(--noora-border-secondary, #e5e7eb);
        outline: none;
        border-radius: var(--noora-radius-full);
      }

      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 16px;
        height: 16px;
        background: var(--noora-accent-primary, #3b82f6);
        cursor: pointer;
        border-radius: 50%;
        transition: transform 0.15s ease;
      }

      input[type="range"]::-webkit-slider-thumb:hover {
        transform: scale(1.1);
      }

      input[type="range"]::-moz-range-thumb {
        width: 16px;
        height: 16px;
        background: var(--noora-accent-primary, #3b82f6);
        cursor: pointer;
        border-radius: 50%;
        border: none;
        transition: transform 0.15s ease;
      }

      input[type="range"]::-moz-range-thumb:hover {
        transform: scale(1.1);
      }

      .range-value {
        display: inline-block;
        margin-left: var(--noora-spacing-3);
        font-weight: 600;
        font-size: 14px;
        color: var(--noora-surface-label-primary, #111827);
      }

      .current-state {
        margin-top: var(--noora-spacing-6);
        padding: var(--noora-spacing-5);
        background: transparent;
        border-radius: var(--noora-radius-medium);
        border: 1px solid var(--noora-border-secondary, #e5e7eb);
        margin-bottom: var(--noora-spacing-6);
      }

      .section-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--noora-surface-label-primary, #111827);
        margin-bottom: var(--noora-spacing-5);
      }

      .comparison-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--noora-surface-label-primary, #111827);
        margin-bottom: var(--noora-spacing-2);
      }

      .comparison-subtitle {
        font-size: 12px;
        color: var(--noora-surface-label-tertiary, #9ca3af);
        margin-bottom: var(--noora-spacing-6);
      }

      .comparison-table {
        margin-top: var(--noora-spacing-6);
        border: 1px solid var(--noora-border-secondary, #e5e7eb);
        border-radius: var(--noora-radius-medium);
        overflow: hidden;
      }

      .comparison-header {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: var(--noora-spacing-3);
        padding: var(--noora-spacing-4);
        background: var(--noora-surface-tertiary, #f9fafb);
        border-bottom: 1px solid var(--noora-border-secondary, #e5e7eb);
      }

      .header-cell {
        font-size: 13px;
        font-weight: 600;
        color: var(--noora-surface-label-secondary, #6b7280);
        text-align: center;
        position: relative;
      }

      .header-cell:first-child {
        text-align: left;
      }

      .header-cell.recommended::after {
        content: "Best ROI";
        position: absolute;
        top: -18px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--noora-accent-primary, #3b82f6);
        color: white;
        padding: 2px 10px;
        border-radius: var(--noora-radius-full);
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
      }

      .comparison-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: var(--noora-spacing-3);
        padding: var(--noora-spacing-4);
        border-bottom: 1px solid var(--noora-border-tertiary, #f3f4f6);
      }

      .comparison-row:last-child {
        border-bottom: none;
      }

      .comparison-row.highlight {
        background: var(--noora-accent-surface, #eff6ff);
      }

      .row-label {
        font-size: 13px;
        color: var(--noora-surface-label-secondary, #6b7280);
        display: flex;
        align-items: center;
      }

      .row-value {
        font-size: 14px;
        font-weight: 600;
        color: var(--noora-surface-label-primary, #111827);
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        font-feature-settings: "tnum";
        font-variant-numeric: tabular-nums;
      }

      .result-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--noora-spacing-3) 0;
        border-bottom: 1px solid var(--noora-border-tertiary, #f3f4f6);
      }

      .result-row:last-child {
        border-bottom: none;
      }

      .result-label {
        font-size: 13px;
        color: var(--noora-surface-label-tertiary, #9ca3af);
      }

      .result-value {
        font-size: 14px;
        font-weight: 600;
        color: var(--noora-surface-label-primary, #111827);
        font-feature-settings: "tnum";
        font-variant-numeric: tabular-nums;
      }

      .result-value.highlight {
        color: var(--noora-accent-primary, #3b82f6);
        font-size: 15px;
      }

      .result-value.negative {
        color: var(--noora-error, #ef4444);
      }

      .result-value.positive {
        color: var(--noora-success, #10b981);
      }

      .winner-summary {
        margin-top: var(--noora-spacing-6);
        padding: var(--noora-spacing-5);
        background: var(--noora-accent-surface, #eff6ff);
        border-radius: var(--noora-radius-medium);
        border: 1px solid var(--noora-accent-border, #bfdbfe);
        text-align: center;
      }

      .winner-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--noora-accent-primary, #3b82f6);
        margin-bottom: var(--noora-spacing-3);
      }

      .winner-text {
        font-size: 13px;
        color: var(--noora-surface-label-secondary, #6b7280);
        line-height: 1.5;
      }

      @media (max-width: 768px) {
        .comparison-header,
        .comparison-row {
          grid-template-columns: 1.5fr 1fr 1fr 1fr;
          font-size: 12px;
        }

        .header-cell,
        .row-label,
        .row-value {
          font-size: 11px;
        }

        .header-cell.recommended::after {
          font-size: 9px;
          padding: 1px 8px;
        }
      }
    </style>
  </head>
  <body>
    <div class="calculator-container">
      <div class="input-group">
        <label class="input-label">
          Team Size
          <span class="range-value" id="team-size-value">30</span>
        </label>
        <input type="range" id="team-size" min="1" max="100" value="30" />
        <div class="input-hint">Number of developers on your team</div>
      </div>

      <div class="input-group">
        <label class="input-label">
          Average CI Time (minutes)
          <span class="range-value" id="ci-time-value">15</span>
        </label>
        <input type="range" id="ci-time" min="1" max="60" value="15" />
        <div class="input-hint">How long does your CI pipeline take?</div>
      </div>

      <div class="input-group">
        <label class="input-label">
          Average Salary (€)
          <span class="range-value" id="salary-value">140,000</span>
        </label>
        <input type="range" id="salary" min="50000" max="250000" step="10000" value="140000" />
        <div class="input-hint">Average annual salary per developer</div>
      </div>

      <div class="input-group">
        <label class="input-label">
          Conflict Rate (%)
          <span class="range-value" id="conflict-rate-value">40</span>
        </label>
        <input type="range" id="conflict-rate" min="0" max="100" value="40" />
        <div class="input-hint">Percentage of PRs that hit merge conflicts</div>
      </div>

      <div class="current-state">
        <div class="section-title">Your Current State</div>
        <div class="result-row">
          <span class="result-label">Commits per Day</span>
          <span class="result-value" id="current-commits">70</span>
        </div>
        <div class="result-row">
          <span class="result-label">Efficiency</span>
          <span class="result-value negative" id="current-efficiency">29%</span>
        </div>
        <div class="result-row">
          <span class="result-label">Annual Salary Cost</span>
          <span class="result-value" id="salary-cost">€4.2M</span>
        </div>
        <div class="result-row">
          <span class="result-label">Wasted Value/Year</span>
          <span class="result-value negative" id="wasted-value">€3.0M</span>
        </div>
      </div>

      <div class="comparison-title">Compare Solutions</div>
      <div class="comparison-subtitle">Three ways to improve throughput. Which has the best ROI?</div>

      <div class="comparison-table">
        <div class="comparison-header">
          <div class="header-cell">Metric</div>
          <div class="header-cell recommended">Workflow Optimization</div>
          <div class="header-cell">Hire More Developers</div>
          <div class="header-cell">Faster CI Hardware</div>
        </div>

        <div class="comparison-row">
          <div class="row-label">Solution</div>
          <div class="row-value">Tuist</div>
          <div class="row-value" id="hire-count">Hire +10 devs</div>
          <div class="row-value" id="hardware-solution">Faster runners</div>
        </div>

        <div class="comparison-row">
          <div class="row-label">Commits per Day</div>
          <div class="row-value positive" id="tuist-commits">150</div>
          <div class="row-value" id="hire-commits">75</div>
          <div class="row-value" id="hardware-commits">80</div>
        </div>

        <div class="comparison-row">
          <div class="row-label">Team Efficiency</div>
          <div class="row-value positive" id="tuist-efficiency">63%</div>
          <div class="row-value negative" id="hire-efficiency">19%</div>
          <div class="row-value" id="hardware-efficiency">33%</div>
        </div>

        <div class="comparison-row">
          <div class="row-label">Annual Cost</div>
          <div class="row-value" id="tuist-cost">€50K</div>
          <div class="row-value negative" id="hire-cost">€1.4M</div>
          <div class="row-value" id="hardware-cost">€300K</div>
        </div>

        <div class="comparison-row highlight">
          <div class="row-label">Net Benefit/Year</div>
          <div class="row-value positive" id="tuist-benefit">€1.4M</div>
          <div class="row-value negative" id="hire-benefit">-€1.3M</div>
          <div class="row-value" id="hardware-benefit">€170K</div>
        </div>

        <div class="comparison-row highlight">
          <div class="row-label">Return on Investment</div>
          <div class="row-value positive" id="tuist-roi">28×</div>
          <div class="row-value negative" id="hire-roi">-1×</div>
          <div class="row-value" id="hardware-roi">1.6×</div>
        </div>
      </div>

      <div class="winner-summary">
        <div class="winner-title">
          Tuist ROI: <span id="tuist-roi-summary" class="positive">20×</span> |
          Hardware ROI: <span id="hardware-roi-summary">1.5×</span> |
          Hiring ROI: <span id="hiring-roi-summary" class="negative">-0.5×</span>
        </div>
        <div class="winner-text">Optimize workflows before hardware. Eliminate waste instead of making it happen faster.</div>
      </div>
    </div>

    <script nonce={get_csp_nonce()}>
      const teamSizeInput = document.getElementById('team-size');
      const ciTimeInput = document.getElementById('ci-time');
      const salaryInput = document.getElementById('salary');
      const conflictRateInput = document.getElementById('conflict-rate');

      const teamSizeValue = document.getElementById('team-size-value');
      const ciTimeValue = document.getElementById('ci-time-value');
      const salaryValue = document.getElementById('salary-value');
      const conflictRateValue = document.getElementById('conflict-rate-value');

      // Current state elements
      const currentCommitsEl = document.getElementById('current-commits');
      const currentEfficiencyEl = document.getElementById('current-efficiency');
      const salaryCostEl = document.getElementById('salary-cost');
      const wastedValueEl = document.getElementById('wasted-value');

      // Tuist solution elements
      const tuistCommitsEl = document.getElementById('tuist-commits');
      const tuistEfficiencyEl = document.getElementById('tuist-efficiency');
      const tuistCostEl = document.getElementById('tuist-cost');
      const tuistBenefitEl = document.getElementById('tuist-benefit');
      const tuistRoiEl = document.getElementById('tuist-roi');

      // Hiring solution elements
      const hireCountEl = document.getElementById('hire-count');
      const hireCommitsEl = document.getElementById('hire-commits');
      const hireEfficiencyEl = document.getElementById('hire-efficiency');
      const hireCostEl = document.getElementById('hire-cost');
      const hireBenefitEl = document.getElementById('hire-benefit');
      const hireRoiEl = document.getElementById('hire-roi');

      // Hardware solution elements
      const hardwareSolutionEl = document.getElementById('hardware-solution');
      const hardwareCommitsEl = document.getElementById('hardware-commits');
      const hardwareEfficiencyEl = document.getElementById('hardware-efficiency');
      const hardwareCostEl = document.getElementById('hardware-cost');
      const hardwareBenefitEl = document.getElementById('hardware-benefit');
      const hardwareRoiEl = document.getElementById('hardware-roi');

      // Summary elements
      const tuistRoiSummaryEl = document.getElementById('tuist-roi-summary');
      const hardwareRoiSummaryEl = document.getElementById('hardware-roi-summary');
      const hiringRoiSummaryEl = document.getElementById('hiring-roi-summary');

      function formatMoney(value) {
        if (value >= 1000000) {
          return '€' + (value / 1000000).toFixed(1) + 'M';
        } else if (value >= 1000) {
          return '€' + (value / 1000).toFixed(0) + 'K';
        }
        return '€' + value.toFixed(0);
      }

      function formatNumber(value) {
        return value.toLocaleString('en-US');
      }

      function calculate() {
        const teamSize = parseInt(teamSizeInput.value);
        const ciTime = parseInt(ciTimeInput.value);
        const salary = parseInt(salaryInput.value);
        const conflictRate = parseInt(conflictRateInput.value) / 100;

        // Update display values
        teamSizeValue.textContent = teamSize;
        ciTimeValue.textContent = ciTime;
        salaryValue.textContent = formatNumber(salary);
        conflictRateValue.textContent = Math.round(conflictRate * 100);

        // Base commit rate per developer (8 commits/day in ideal conditions)
        const baseCommitRate = 8;
        const expectedCommits = Math.round(teamSize * baseCommitRate);

        // Calculate current efficiency based on team size, CI time, and conflicts
        // Use more modest overhead calculations
        const coordinationOverhead = Math.min(0.6, (teamSize - 1) * 0.015); // Less harsh
        const ciOverhead = Math.min(0.3, (ciTime / 60) * 0.25); // Less harsh
        const conflictOverhead = conflictRate * 0.2; // Less harsh
        const totalOverhead = coordinationOverhead + ciOverhead + conflictOverhead;
        const currentEfficiency = Math.max(0.15, 1 - totalOverhead); // Higher minimum
        const currentCommits = Math.round(expectedCommits * currentEfficiency);

        // Calculate costs
        const totalSalaryCost = teamSize * salary;
        const wastedValue = totalSalaryCost * (1 - currentEfficiency);

        // SOLUTION 1: Tuist (workflow optimization)
        const tuistCiTime = Math.max(1, Math.round(ciTime * 0.2)); // 80% CI reduction
        const tuistEfficiency = Math.min(0.75, currentEfficiency * 2.0); // Significant boost
        const tuistCommits = Math.round(expectedCommits * tuistEfficiency);
        const tuistAnnualCost = Math.round(teamSize * 60 * 12); // €60/dev/month
        const tuistValueUnlocked = (tuistEfficiency - currentEfficiency) * totalSalaryCost;
        const tuistNetBenefit = tuistValueUnlocked - tuistAnnualCost;
        const tuistROI = tuistNetBenefit / tuistAnnualCost;

        // SOLUTION 2: Hire more developers
        const additionalDevs = Math.round(teamSize * 0.33); // Hire 33% more
        const newTeamSize = teamSize + additionalDevs;
        const newExpectedCommits = Math.round(newTeamSize * baseCommitRate);
        // Coordination overhead increases but not dramatically
        const newCoordinationOverhead = Math.min(0.65, (newTeamSize - 1) * 0.015);
        const newTotalOverhead = newCoordinationOverhead + ciOverhead + conflictOverhead * 1.15;
        const hireEfficiency = Math.max(0.15, 1 - newTotalOverhead);
        const hireCommits = Math.round(newExpectedCommits * hireEfficiency);
        const hireAnnualCost = additionalDevs * salary;
        const hireValueUnlocked = (hireCommits - currentCommits) / baseCommitRate * salary;
        const hireNetBenefit = hireValueUnlocked - hireAnnualCost;
        const hireROI = hireNetBenefit / hireAnnualCost;

        // SOLUTION 3: Faster hardware (cuts CI time by ~50%)
        const hardwareCiTime = Math.max(3, Math.round(ciTime * 0.5));
        const hardwareCiOverhead = Math.min(0.3, (hardwareCiTime / 60) * 0.25);
        const hardwareTotalOverhead = coordinationOverhead + hardwareCiOverhead + conflictOverhead;
        const hardwareEfficiency = Math.max(0.15, 1 - hardwareTotalOverhead);
        const hardwareCommits = Math.round(expectedCommits * hardwareEfficiency);
        // Hardware cost scales with team size (~€10K per developer annually)
        const hardwareAnnualCost = Math.round(teamSize * 10000);
        const hardwareValueUnlocked = (hardwareEfficiency - currentEfficiency) * totalSalaryCost;
        const hardwareNetBenefit = hardwareValueUnlocked - hardwareAnnualCost;
        const hardwareROI = hardwareNetBenefit / hardwareAnnualCost;

        // Update current state
        currentCommitsEl.textContent = currentCommits;
        currentEfficiencyEl.textContent = Math.round(currentEfficiency * 100) + '%';
        salaryCostEl.textContent = formatMoney(totalSalaryCost);
        wastedValueEl.textContent = formatMoney(wastedValue);

        // Update Tuist solution
        tuistCommitsEl.textContent = tuistCommits;
        tuistEfficiencyEl.textContent = Math.round(tuistEfficiency * 100) + '%';
        tuistCostEl.textContent = formatMoney(tuistAnnualCost);
        tuistBenefitEl.textContent = formatMoney(tuistNetBenefit);
        tuistRoiEl.textContent = tuistROI.toFixed(0) + '×';

        // Update hiring solution
        hireCountEl.textContent = 'Hire +' + additionalDevs + ' devs (33%)';
        hireCommitsEl.textContent = hireCommits;
        hireEfficiencyEl.textContent = Math.round(hireEfficiency * 100) + '%';
        hireCostEl.textContent = formatMoney(hireAnnualCost);
        hireBenefitEl.textContent = formatMoney(hireNetBenefit);
        hireRoiEl.textContent = hireROI.toFixed(1) + '×';

        // Update hardware solution
        hardwareSolutionEl.textContent = 'Faster runners (€10K/dev)';
        hardwareCommitsEl.textContent = hardwareCommits;
        hardwareEfficiencyEl.textContent = Math.round(hardwareEfficiency * 100) + '%';
        hardwareCostEl.textContent = formatMoney(hardwareAnnualCost);
        hardwareBenefitEl.textContent = formatMoney(hardwareNetBenefit);
        hardwareRoiEl.textContent = hardwareROI.toFixed(1) + '×';

        // Update ROI summary comparison
        tuistRoiSummaryEl.textContent = tuistROI.toFixed(0) + '×';
        hardwareRoiSummaryEl.textContent = hardwareROI.toFixed(1) + '×';
        hiringRoiSummaryEl.textContent = hireROI.toFixed(1) + '×';
      }

      // Add event listeners
      teamSizeInput.addEventListener('input', calculate);
      ciTimeInput.addEventListener('input', calculate);
      salaryInput.addEventListener('input', calculate);
      conflictRateInput.addEventListener('input', calculate);

      // Initial calculation
      calculate();
    </script>
  </body>
</html>
