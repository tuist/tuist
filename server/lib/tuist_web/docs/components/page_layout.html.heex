<main
  id="docs-page-layout"
  data-part="page"
  phx-hook="DocsActivePage"
  data-current-slug={@current_slug}
  data-current-tab={@tab}
>
  <section data-part="layout">
    <nav
      id="docs-sidebar"
      data-part="sidebar"
      aria-label="Documentation navigation"
      phx-update="ignore"
    >
      <.link patch="/docs/en" data-part="nav-link">
        <.tab_menu_vertical label="Overview" data-selected={@current_slug == "/en"}>
          <:icon_left>
            <.icon name="smart_home" />
          </:icon_left>
        </.tab_menu_vertical>
      </.link>
      <div :for={group <- @tree} data-part="nav-section">
        <.line_divider />
        <div data-part="content-divider">
          <.icon name={group_icon(group.label)} />
          <span>{group.label}</span>
        </div>
        <.nav_items items={group.items} current_slug={@current_slug} />
      </div>
    </nav>
    <div data-part="content">
      {render_slot(@inner_block)}
    </div>
    <.toc :if={@headings != []} headings={@headings} />
  </section>
</main>
