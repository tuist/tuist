<aside data-part="toc" aria-label={dgettext("docs", "Table of contents")}>
  <span data-part="title">{dgettext("docs", "On this page")}</span>
  <ul data-part="list">
    <li :for={heading <- @headings} data-part="item" data-level={heading.level}>
      <a href={"##{heading.id}"}>{heading.text}</a>
    </li>
  </ul>
</aside>
