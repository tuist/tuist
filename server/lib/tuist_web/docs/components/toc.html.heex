<aside id="docs-toc" aria-label={dgettext("docs", "Table of contents")}>
  <div data-part="toc-actions">
    <.button_dropdown
      :if={@markdown != ""}
      id="docs-copy-dropdown"
      label={dgettext("docs", "Copy page")}
      size="medium"
      phx-hook="DocsCopyPageButton"
      data-default-label={dgettext("docs", "Copy page")}
      data-copied-label={dgettext("docs", "Copied")}
      data-markdown-source-id="docs-page-markdown"
    >
      <:icon_left><.copy /></:icon_left>
      <.dropdown_item
        label={dgettext("docs", "Copy page")}
        description={dgettext("docs", "Copy page as markdown for LLMs")}
        value="copy-markdown"
        size="large"
        on_click="copy-page-markdown"
      >
        <:left_icon><.copy /></:left_icon>
      </.dropdown_item>
      <.dropdown_item
        label={dgettext("docs", "View as Markdown")}
        description={dgettext("docs", "View this page as plain text")}
        value="view-markdown"
        href={docs_markdown_path(@current_slug)}
        size="large"
        target="_blank"
        rel="noopener noreferrer"
      >
        <:left_icon><.icon name="markdown" /></:left_icon>
        <:right_icon><.external_link /></:right_icon>
      </.dropdown_item>
    </.button_dropdown>
  </div>
  <div data-part="toc-header">
    <.list_tree />
    <span>{dgettext("docs", "On this page")}</span>
  </div>
  <ul data-part="list">
    <li :for={heading <- @headings} data-part="item">
      <a href={"##{heading.id}"} data-level={heading.level}>{heading.text}</a>
    </li>
  </ul>
</aside>
