<!DOCTYPE html>
<html lang={Gettext.get_locale(TuistWeb.Gettext)} class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csp-nonce" content={get_csp_nonce()} />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title>
      {assigns[:page_title] || assigns[:head_title] || "Tuist"}
    </.live_title>
    <TuistWeb.LayoutComponents.head_meta_meta_tags {assigns} />
    <TuistWeb.LayoutComponents.head_x_meta_tags {assigns} />
    <!-- Assets -->
    <link phx-track-static rel="stylesheet" href={~p"/docs/assets/bundle.css"} />
    <script defer phx-track-static type="module" src={~p"/docs/assets/bundle.js"}>
    </script>
    <style nonce={get_csp_nonce()}>
      pre.mermaid:not([data-processed="true"]) { visibility: hidden; }
    </style>
    <script nonce={get_csp_nonce()} type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      mermaid.initialize({
        startOnLoad: true,
        securityLevel: "loose",
        theme: "base",
        themeVariables: {
          primaryColor: "#f1f2f4",
          primaryBorderColor: "#c7ccd1",
          primaryTextColor: "#171a1c",
          secondaryColor: "#f9fafa",
          tertiaryColor: "#fdfdfd",
          lineColor: "#848f9a",
          textColor: "#171a1c",
          fontFamily: "Inter, sans-serif",
          fontSize: "14px",
          nodeBorder: "#c7ccd1",
          nodeTextColor: "#171a1c",
          edgeLabelBackground: "#fdfdfd",
        },
      });
      document.addEventListener("phx:page-loading-stop", () => {
        mermaid.run({ querySelector: ".mermaid" });
      });
    </script>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <!-- Analytics -->
    <TuistWeb.LayoutComponents.head_analytics_scripts page_section="docs" {assigns} />
    <TuistWeb.LayoutComponents.head_plain_script current_user={assigns[:current_user]} {assigns} />
    <link rel="canonical" href={Tuist.Environment.app_url(path: @current_path)} />
    <meta property="og:locale" content={@locale} />
    <link
      :for={lang <- TuistWeb.Marketing.Localization.languages()}
      rel="alternate"
      hreflang={lang.code}
      href={Tuist.Environment.app_url(path: localized_docs_href(@current_path, lang.code))}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={Tuist.Environment.app_url(path: localized_docs_href(@current_path, "en"))}
    />
  </head>
  <body data-scrollable="true">
    <a href="#docs-content" class="docs-skip-link">
      {dgettext("docs", "Skip to content")}
    </a>
    <nav id="docs-nav" aria-label={dgettext("docs", "Main navigation")}>
      <div data-part="header">
        <.link navigate={docs_path("/#{@locale}")} data-part="logo-link">
          <img data-part="logo" src={~p"/docs/images/logo.webp"} alt="Tuist" />
          <span data-part="logo-divider"></span>
          <span data-part="logo-text">Docs</span>
        </.link>
        <.button_group size="large" id="docs-nav-tabs">
          <.button_group_item
            label={dgettext("docs", "Guides")}
            href={docs_path("/#{@locale}")}
            data-tab="guides"
            data-selected={
              !String.contains?(@current_path, "/docs/references") &&
                !String.contains?(@current_path, "/docs/contributors") &&
                !String.contains?(@current_path, "/docs/cli")
            }
          />
          <.button_group_item
            label={dgettext("docs", "CLI")}
            href={docs_path("/#{@locale}/cli")}
            data-tab="cli"
            data-selected={String.contains?(@current_path, "/docs/cli")}
          />
          <.button_group_item
            label={dgettext("docs", "References")}
            href={docs_path("/#{@locale}/references/tuist-toml")}
            data-tab="references"
            data-selected={String.contains?(@current_path, "/docs/references")}
          />
          <.button_group_item
            label={dgettext("docs", "Resources")}
            href={docs_path("/#{@locale}/contributors/code")}
            data-tab="resources"
            data-selected={String.contains?(@current_path, "/docs/contributors")}
          />
        </.button_group>
      </div>
      <div data-part="cta">
        <.text_input
          id="text-input-types-search"
          name="search"
          type="search"
          placeholder="Search..."
        />

        <.inline_dropdown id="docs-language-selector" label={language_name(@locale)}>
          <.dropdown_item
            :for={lang <- TuistWeb.Marketing.Localization.languages()}
            label={lang.native}
            value={lang.code}
            navigate={localized_docs_href(@current_path, lang.code)}
          />
        </.inline_dropdown>

        <div data-part="socials">
          <.neutral_button
            size="large"
            href="https://github.com/tuist/tuist"
            target="_blank"
            aria-label={dgettext("docs", "GitHub")}
          >
            <.brand_github />
          </.neutral_button>
          <.neutral_button
            size="large"
            href="https://fosstodon.org/@tuist"
            target="_blank"
            aria-label={dgettext("docs", "Mastodon")}
          >
            <.brand_mastodon />
          </.neutral_button>
          <.neutral_button
            size="large"
            href="https://slack.tuist.dev"
            target="_blank"
            aria-label={dgettext("docs", "Slack")}
          >
            <.brand_slack />
          </.neutral_button>
          <.neutral_button
            size="large"
            href="https://bsky.app/profile/tuist.dev"
            target="_blank"
            aria-label={dgettext("docs", "Bluesky")}
          >
            <.brand_bluesky />
          </.neutral_button>
        </div>
        <.button
          :if={is_nil(assigns[:current_user])}
          label={dgettext("docs", "Log in")}
          variant="primary"
          size="small"
          href={~p"/docs/login?#{%{return_to: @current_path}}"}
        />
      </div>
      <div data-part="mobile-actions">
        <.neutral_button size="large" aria-label={dgettext("docs", "Search")}>
          <.icon name="search" />
        </.neutral_button>
        <.neutral_button
          size="large"
          aria-label={dgettext("docs", "Toggle sidebar")}
          aria-expanded="false"
          aria-controls="docs-sidebar"
          phx-click={
            JS.toggle_attribute({"data-sidebar-open", ""}, to: "body")
            |> JS.toggle_attribute({"data-mobile-open", ""}, to: "#docs-sidebar")
          }
        >
          <.icon name="menu" />
        </.neutral_button>
      </div>
    </nav>
    <div id="docs-mobile-menu-bar" role="toolbar" aria-label={dgettext("docs", "Page navigation")}>
      <button
        type="button"
        data-part="mobile-menu-btn"
        id="docs-mobile-menu-trigger"
        aria-expanded="false"
        aria-controls="docs-sidebar"
        phx-click={
          JS.toggle_attribute({"data-sidebar-open", ""}, to: "body")
          |> JS.toggle_attribute({"data-mobile-open", ""}, to: "#docs-sidebar")
          |> JS.toggle_attribute({"aria-expanded", "true", "false"},
            to: "#docs-mobile-menu-trigger"
          )
        }
      >
        <.icon name="menu_3" />
        <span>{dgettext("docs", "Menu")}</span>
      </button>
      <button
        type="button"
        data-part="mobile-toc-btn"
        id="docs-mobile-toc-trigger"
        aria-expanded="false"
        aria-controls="docs-mobile-toc"
        phx-click={JS.toggle_attribute({"data-state", "open", "closed"}, to: "#docs-mobile-toc")}
      >
        <span>{dgettext("docs", "On this page")}</span>
        <.icon name="news" />
      </button>
    </div>
    <div
      id="docs-mobile-sidebar-overlay"
      role="presentation"
      phx-click={
        JS.remove_attribute("data-sidebar-open", to: "body")
        |> JS.remove_attribute("data-mobile-open", to: "#docs-sidebar")
        |> JS.set_attribute({"aria-expanded", "false"}, to: "#docs-mobile-menu-trigger")
      }
    >
    </div>
    <TuistWeb.Docs.Components.search_modal
      host={Tuist.Environment.typesense_host()}
      api_key={Tuist.Environment.typesense_search_api_key()}
      locale={@locale}
      placeholder={dgettext("docs", "Search...")}
    />
    {@inner_content}
  </body>
</html>
