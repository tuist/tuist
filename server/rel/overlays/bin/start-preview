#!/bin/sh
cd -P -- "$(dirname -- "$0")"

# Derive TUIST_APP_URL from Render's automatic RENDER_EXTERNAL_URL if not already set.
if [ -z "$TUIST_APP_URL" ] && [ -n "$RENDER_EXTERNAL_URL" ]; then
  export TUIST_APP_URL="$RENDER_EXTERNAL_URL"
  echo "Set TUIST_APP_URL=${TUIST_APP_URL} from RENDER_EXTERNAL_URL"
fi

# Render's generateValue produces short random strings. Phoenix requires
# secret_key_base to be at least 64 bytes. Repeat the value until long enough.
for key_var in TUIST_SECRET_KEY_BASE TUIST_SECRET_KEY_PASSWORD TUIST_SECRET_KEY_TOKENS TUIST_SECRET_KEY_ENCRYPTION; do
  eval "key_val=\$$key_var"
  if [ -n "$key_val" ] && [ ${#key_val} -lt 64 ]; then
    padded="$key_val"
    while [ ${#padded} -lt 64 ]; do
      padded="${padded}${key_val}"
    done
    export "$key_var=$padded"
    echo "Extended $key_var from ${#key_val} to ${#padded} bytes"
  fi
done

# Start ClickHouse in the background (installed in the Docker image for preview builds).
# Runs on localhost with no auth (only accessible within this container).
CLICKHOUSE_DB="tuist_preview"
CLICKHOUSE_BASE_URL="http://127.0.0.1:8123"
export TUIST_CLICKHOUSE_URL="${CLICKHOUSE_BASE_URL}/${CLICKHOUSE_DB}"

echo "Starting embedded ClickHouse..."
clickhouse-server --config-file=/etc/clickhouse-server/config.xml 2>&1 &
CH_PID=$!
echo "  ClickHouse started with PID $CH_PID"

# Run PostgreSQL migrations first (they don't need ClickHouse).
echo "Obtaining the database schema version..."
BEFORE_MIGRATION_SCHEMA_VERSION=$(psql "$DATABASE_URL" -t -c "SELECT version FROM schema_migrations ORDER BY version DESC LIMIT 1;" 2>/dev/null || echo "")
BEFORE_MIGRATION_SCHEMA_VERSION=$(echo $BEFORE_MIGRATION_SCHEMA_VERSION | xargs)

if [ -n "$BEFORE_MIGRATION_SCHEMA_VERSION" ]; then
  echo "Current database schema version: $BEFORE_MIGRATION_SCHEMA_VERSION"
else
  echo "Fresh database - no existing schema version."
fi

echo "Running PostgreSQL migrations..."
./tuist eval Tuist.Release.migrate_main
if [ $? -ne 0 ]; then
  echo "PostgreSQL migration failed!"
  AFTER_MIGRATION_SCHEMA_VERSION=$(psql "$DATABASE_URL" -t -c "SELECT version FROM schema_migrations ORDER BY version DESC LIMIT 1;" 2>/dev/null || echo "")
  AFTER_MIGRATION_SCHEMA_VERSION=$(echo $AFTER_MIGRATION_SCHEMA_VERSION | xargs)

  if [ -n "$BEFORE_MIGRATION_SCHEMA_VERSION" ] && [ "$BEFORE_MIGRATION_SCHEMA_VERSION" != "$AFTER_MIGRATION_SCHEMA_VERSION" ]; then
    echo "Rolling back from version $AFTER_MIGRATION_SCHEMA_VERSION to $BEFORE_MIGRATION_SCHEMA_VERSION (excluded)"
    ROLLBACK_VERSION=$BEFORE_MIGRATION_SCHEMA_VERSION ./tuist eval Tuist.Release.rollback
  fi
  exit 1
fi
echo "PostgreSQL migration completed successfully."

# Wait for ClickHouse, run its migrations, and seed the database in the background.
# ClickHouse takes 60-120s to start on Render, so we can't block server startup.
# The Ch.Connection pool retries automatically, and the seed runs once ClickHouse is ready.
(
  echo "Background: waiting for ClickHouse to accept connections..."
  CH_READY=false
  for i in $(seq 1 300); do
    if curl -sf4 "${CLICKHOUSE_BASE_URL}/ping" > /dev/null 2>&1; then
      CH_READY=true
      echo "Background: ClickHouse is ready (after ${i}s). Resetting database..."
      curl -sf4 "${CLICKHOUSE_BASE_URL}/" --data "DROP DATABASE IF EXISTS ${CLICKHOUSE_DB}"
      curl -sf4 "${CLICKHOUSE_BASE_URL}/" --data "CREATE DATABASE ${CLICKHOUSE_DB}"
      echo "Background: ClickHouse database '${CLICKHOUSE_DB}' ready."

      echo "Background: Running ClickHouse migrations..."
      ./tuist eval Tuist.Release.migrate_ingest
      echo "Background: ClickHouse migrations completed."

      echo "Background: Seeding the database..."
      ./tuist eval Tuist.Release.seed
      echo "Background: Seeding completed."
      break
    fi
    if [ "$((i % 30))" = "0" ]; then
      echo "Background: still waiting for ClickHouse... (${i}s)"
    fi
    sleep 1
  done
  if [ "$CH_READY" = "false" ]; then
    echo "Background: ClickHouse failed to start within 300s. Skipping migrations and seed."
  fi
) &

# Start the server immediately so Render detects the port.
echo "Starting the server..."
TUIST_WEB=true exec ./tuist start
