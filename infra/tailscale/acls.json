// Tuist tailnet ACLs.
//
// Single source of truth for who-can-talk-to-what on the Tuist
// tailnet. Mirror this file into the Tailscale admin console under
// "Access controls" — Tailscale doesn't have a public API for ACL
// sync, so updates land via the console UI. The file lives in the
// repo so changes go through code review, not via someone's
// browser session.
//
// Tag taxonomy:
//
//   tag:tuist-macmini        Every Mac mini in any of Tuist's
//                            macOS fleets — xcresult-processor,
//                            customer-runner pool, future fleets.
//                            Joined via the bootstrap step in
//                            infra/macos-host-bootstrap.
//   tag:tuist-k8s-operator   The Tailscale K8s operator + the
//                            cluster-side subnet-router Connector
//                            it provisions. Allowed to dial the
//                            scrape ports on tag:tuist-macmini.
//   tag:tuist-ops            Human operators with SSH access to
//                            Mac minis. Not used by automation;
//                            assign to user devices via the
//                            "Users & groups" UI.
//
// Tag ownership: tagOwners gates *who can apply this tag at
// `tailscale up` / auth-key issuance*. The Tuist team account is
// the only owner — the bootstrap auth key is issued with the tag
// baked in; OAuth clients for the K8s operator advertise their
// own tag through the operator's `defaultTags` config.

{
  "tagOwners": {
    "tag:tuist-macmini": ["autogroup:admin"],
    "tag:tuist-k8s-operator": ["autogroup:admin"],
    "tag:tuist-ops": ["autogroup:admin"]
  },

  "acls": [
    // Cluster scraper path: alloy-metrics (which goes out via the
    // K8s operator's subnet router) dials the macOS fleet on:
    //   :9091  PromEx on the xcresult-processor Tart VM,
    //          fronted by tart-kubelet's host-side Forwarder.
    //   :9100  node_exporter on the Mac mini host itself.
    {
      "action": "accept",
      "src": ["tag:tuist-k8s-operator"],
      "dst": ["tag:tuist-macmini:9091", "tag:tuist-macmini:9100"]
    },

    // Human ops: SSH into Mac minis when CAPI controller hits an
    // edge case the drift loop can't resolve. Not a load-bearing
    // path — the CAPI provider's per-fleet SSH key is the normal
    // way the controller reaches the fleet. This is for humans.
    {
      "action": "accept",
      "src": ["tag:tuist-ops"],
      "dst": ["tag:tuist-macmini:22"]
    }
  ],

  // Default deny: anything not explicitly allowed above is
  // dropped. Tailscale defaults to "allow all" if no rules match —
  // ssh/explicit rules above make this implicit, but keeping the
  // comment as documentation.

  "tests": [
    {
      "src": "tag:tuist-k8s-operator",
      "accept": ["tag:tuist-macmini:9091", "tag:tuist-macmini:9100"],
      "deny": ["tag:tuist-macmini:22"]
    },
    {
      "src": "tag:tuist-ops",
      "accept": ["tag:tuist-macmini:22"],
      "deny": ["tag:tuist-macmini:9091", "tag:tuist-macmini:9100"]
    }
  ]
}
