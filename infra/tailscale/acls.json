// Tuist tailnet ACLs.
//
// Source of truth for who-can-talk-to-what on the Tuist tailnet.
// Mirror this file into the Tailscale admin console under "Access
// controls"; Tailscale doesn't have a public API for ACL sync, so
// updates land via the console UI. The file lives in the repo so
// changes go through code review, not via someone's browser
// session.
//
// Tag taxonomy:
//
//   tag:tuist-mgmt           Tuist team's management devices
//                            (Talos node access, ops laptops).
//                            Inherited from the tailnet's initial
//                            setup.
//   tag:tuist-macmini-<env>  Mac minis in a specific env's macOS
//                            fleet (xcresult-processor, customer
//                            runners, future fleets). Joined via
//                            infra/macos-host-bootstrap; the env
//                            suffix is set by the operator-image
//                            flag --tailscale-tags, which the chart
//                            wires from macosFleet.tailscale.tags
//                            per env values file.
//   tag:tuist-k8s-<env>      Tailscale K8s operator + the cluster-
//                            side subnet-router Connector it
//                            provisions, scoped to one env's
//                            cluster. Each env runs its own
//                            operator instance with its own OAuth
//                            client, so a leaked staging credential
//                            can't enroll a device under a prod
//                            tag.
//   tag:tuist-ops            Human operators with SSH access to
//                            every macOS fleet, regardless of env.
//                            Env-agnostic deliberately — humans
//                            manage all envs, the tag-per-env
//                            split is for credential isolation,
//                            not human access boundaries.

{
	// Human access groups for the Kubernetes API server proxy.
	//
	// Identity for the cluster grants below is sourced from the
	// tailnet role (Owner/Admin/Member, set in the Tailscale admin
	// console Users page) via Tailscale's built-in autogroups:
	//   autogroup:owner  + autogroup:admin   → cluster admins
	//   autogroup:member                     → engineers
	// No email lists are kept in this file; promoting someone in
	// the console flips their access on the next session.
	//
	// This document is the **view-tier** policy only. Elevated
	// access (writes) flows through a separate Pomerium gateway
	// that gates per-request on a Tuist DB flag — no Tailscale
	// policy mutation. So there are no "break-glass" groups
	// declared here, and the ACL itself is humans-only, edited
	// through code review.
	"groups": {},

	"tagOwners": {
		"tag:tuist-mgmt":              ["autogroup:admin"],
		"tag:tuist-ops":               ["autogroup:admin"],
		"tag:tuist-k8s-staging":       ["autogroup:admin"],
		"tag:tuist-k8s-canary":        ["autogroup:admin"],
		"tag:tuist-k8s-production":    ["autogroup:admin"],
		"tag:tuist-macmini-staging":   ["autogroup:admin"],
		"tag:tuist-macmini-canary":    ["autogroup:admin"],
		"tag:tuist-macmini-production":["autogroup:admin"],
	},

	"grants": [
		// Catch-all wide-open rule inherited from the tailnet's
		// initial setup. Kept until a separate audit narrows it
		// without breaking management access (Talos node, ops
		// laptops). The explicit env-pair rules below are subsumed
		// by this today; they're documented so the macOS fleet
		// keeps working when this rule is removed.
		{"src": ["*"], "dst": ["*"], "ip": ["*"]},

		// Per-env operator → matching-env Mac mini fleet on the
		// three scrape ports:
		//   :8080  controller-runtime metrics on tart-kubelet
		//          (reconcile counts, errors, and the
		//          tart_kubelet_vm_boot_duration_seconds histogram).
		//   :9091  PromEx on the xcresult-processor Tart VM,
		//          fronted by tart-kubelet's host-side Forwarder.
		//   :9100  node_exporter on the Mac mini host.
		//
		// Cross-env scraping (staging operator → prod macmini) is
		// blocked at the tailnet layer once the wide-open rule
		// above is removed. Today it's blocked in practice anyway
		// because the CAPI controller in env X only materialises
		// per-mini egress Services for env X's Mac minis (each
		// cluster runs its own controller against its own set of
		// ScalewayAppleSiliconMachines), so alloy-metrics never
		// gets a cross-env target to dial. The explicit per-pair
		// grants here make the boundary load-bearing rather than
		// coincidental.
		{
			"src": ["tag:tuist-k8s-staging"],
			"dst": ["tag:tuist-macmini-staging"],
			"ip":  ["tcp:8080", "tcp:9091", "tcp:9100"],
		},
		{
			"src": ["tag:tuist-k8s-canary"],
			"dst": ["tag:tuist-macmini-canary"],
			"ip":  ["tcp:8080", "tcp:9091", "tcp:9100"],
		},
		{
			"src": ["tag:tuist-k8s-production"],
			"dst": ["tag:tuist-macmini-production"],
			"ip":  ["tcp:8080", "tcp:9091", "tcp:9100"],
		},

		// Same-env Mac mini fleet → CNPG pooler proxy on tcp:5432.
		// The Tailscale operator-managed proxy (rendered with the
		// `tailscale.com/expose` + `tailscale.com/tags` annotations
		// in postgresql-cnpg-pooler.yaml) registers under
		// `tag:tuist-k8s-<env>` — the operator's OAuth client is
		// only authorised to mint that tag today, so the proxy
		// shares it with the cluster's subnet router rather than
		// carrying a dedicated `tag:tuist-pg-pooler-<env>` tag.
		// That makes the dst here wider than the proxy alone, but
		// the catch-all above already subsumes that today; this is
		// the load-bearing rule for when the catch-all is removed.
		// Follow-up to narrow further: provision a dedicated proxy
		// tag in the OAuth client, list it under tagOwners below,
		// and swap the `tailscale.com/tags` annotation on the
		// Pooler CR to use it.
		{
			"src": ["tag:tuist-macmini-staging"],
			"dst": ["tag:tuist-k8s-staging"],
			"ip":  ["tcp:5432"],
		},
		{
			"src": ["tag:tuist-macmini-canary"],
			"dst": ["tag:tuist-k8s-canary"],
			"ip":  ["tcp:5432"],
		},
		{
			"src": ["tag:tuist-macmini-production"],
			"dst": ["tag:tuist-k8s-production"],
			"ip":  ["tcp:5432"],
		},

		// Staging Mac mini fleet → the staging cluster's Service CIDR,
		// through the cluster-side subnet-router Connector
		// (infra/helm/tailscale-operator/values-staging.yaml advertises
		// 10.128.0.0/12; infra/k8s/clusters/cluster-staging.yaml is the
		// source of truth for the CIDR). This is the macOS runner-cache
		// path: Tart runner VMs on the minis dial the account's private
		// Kura node at its ClusterIP — 4000 (HTTP cache API) + 50051
		// (gRPC), mirroring the Linux runner namespace's egress
		// carve-out in infra/helm/tuist/templates/runners-namespace.yaml
		// — plus cluster DNS on 53 (kube-dns ClusterIP lives in the same
		// range) so the VM's /etc/resolver entry can resolve
		// `*.svc.cluster.local` names. Subnet-routed destinations are
		// matched by CIDR, not by the router's tag, hence the literal
		// prefix in dst. Per-account isolation is enforced at the Kura
		// app layer (the tuist.lua tenant hook verifies the build's JWT),
		// same as for Linux runners.
		//
		// Staging only for now: all envs share this Service CIDR, so the
		// CIDR-dst grant can't distinguish envs — it points at whichever
		// env's Connector advertises the route. Keep this aligned with
		// the single-advertiser rule documented in the tailscale-operator
		// chart values before adding canary/production entries.
		{
			"src": ["tag:tuist-macmini-staging"],
			"dst": ["10.128.0.0/12"],
			"ip":  ["tcp:4000", "tcp:50051", "tcp:53", "udp:53"],
		},

		// Humans SSH into any Mac mini. Not load-bearing — the
		// CAPI provider's per-fleet SSH key is the normal path the
		// controller takes. tag:tuist-ops is env-agnostic because
		// the same humans manage all envs.
		{
			"src": ["tag:tuist-ops"],
			"dst": [
				"tag:tuist-macmini-staging",
				"tag:tuist-macmini-canary",
				"tag:tuist-macmini-production",
			],
			"ip": ["tcp:22"],
		},

		// Human kubectl access to workload clusters is NOT a
		// tailnet grant — Pomerium per env handles it via Google
		// Workspace OIDC (`kube-<env>.tuist.dev`) + per-request
		// impersonation resolved by tuist-ops's PolicyController.
		// See `infra/helm/pomerium/`. No `tailscale.com/cap/kubernetes`
		// grants belong in this file.

		// Elevated (`edit`) access for writes does NOT live here.
		// It flows through the Pomerium gateway (see
		// `infra/helm/pomerium/`), which authenticates callers via
		// Google Workspace OIDC, looks up the active elevation in
		// the tuist-ops DB per request, and injects the
		// Impersonate-Group header that maps to the env's elevated
		// ClusterRole. The tailnet ACL stays read-only and static —
		// no runtime mutation, no break-glass groups, and no
		// role-tier branching at this layer (Pomerium ext_authz
		// owns that decision).
	],

	// Subnet-route auto-approval, so the staging Connector's
	// advertised Service CIDR goes live on `helm upgrade` without a
	// human clicking "approve" in the admin console (the Connector
	// Pod re-advertises on every recreate; manual approval would
	// break the route on each rollout). Scoped to the staging
	// cluster tag — the 100.64.0.0/10 advertisement predates this
	// file's autoApprovers section and stays manually approved.
	"autoApprovers": {
		"routes": {
			"10.128.0.0/12": ["tag:tuist-k8s-staging"],
		},
	},

	// Tailscale SSH (distinct from "grants"). The same-env
	// k8s→macmini accept grants let the cluster-side subnet-router
	// `tailscale ssh admin@<vm-tailnet-ip>` into matching-env Mac
	// mini hosts + the Tart VMs that run on them — diagnostic
	// shell access when `kubectl logs` / `kubectl exec` against
	// the kubelet endpoint fails (tart-kubelet's Node hostname
	// doesn't resolve from the K8s apiserver's DNS, so the
	// standard debug path is broken on macOS fleets and this is
	// the substitute).
	//
	// Locked down to the `admin` user only — the bake-time user
	// that owns /opt/tuist and the launchd plist. Explicitly
	// excludes `root` and the broader `autogroup:nonroot` to keep
	// a compromise of the k8s tag (large blast radius — cluster
	// subnet router, every operator pod the Tailscale operator
	// exposes) from being a root-shell pivot. Tagged-device SSH
	// can't use `check` mode (no re-auth flow for a non-human
	// source), so `accept` is the only option and the narrowing
	// happens via `users`. See sshTests below.
	"ssh": [
		{
			"action": "check",
			"src":    ["autogroup:member"],
			"dst":    ["autogroup:self"],
			"users":  ["autogroup:nonroot", "root"],
		},
		{
			"action": "accept",
			"src":    ["tag:tuist-k8s-staging"],
			"dst":    ["tag:tuist-macmini-staging"],
			"users":  ["admin"],
		},
		{
			"action": "accept",
			"src":    ["tag:tuist-k8s-canary"],
			"dst":    ["tag:tuist-macmini-canary"],
			"users":  ["admin"],
		},
		{
			"action": "accept",
			"src":    ["tag:tuist-k8s-production"],
			"dst":    ["tag:tuist-macmini-production"],
			"users":  ["admin"],
		},
	],

	// SSH ACL assertions, enforced on every save in the admin
	// console. The accept lines lock in the `admin`-only narrowing
	// added with #11134's diagnostic grants; the reject lines
	// catch the failure modes that would re-expand blast radius
	// — root SSH (host take-over) or cross-env SSH (staging
	// subnet router into production VMs).
	"sshTests": [
		{
			"src":    "tag:tuist-k8s-staging",
			"dst":    ["tag:tuist-macmini-staging"],
			"accept": ["admin"],
		},
		{
			"src":    "tag:tuist-k8s-staging",
			"dst":    ["tag:tuist-macmini-staging"],
			"deny":   ["root"],
		},
		{
			"src":    "tag:tuist-k8s-staging",
			"dst":    ["tag:tuist-macmini-production"],
			"deny":   ["admin"],
		},
		{
			"src":    "tag:tuist-k8s-canary",
			"dst":    ["tag:tuist-macmini-canary"],
			"accept": ["admin"],
		},
		{
			"src":    "tag:tuist-k8s-canary",
			"dst":    ["tag:tuist-macmini-canary"],
			"deny":   ["root"],
		},
		{
			"src":    "tag:tuist-k8s-production",
			"dst":    ["tag:tuist-macmini-production"],
			"accept": ["admin"],
		},
		{
			"src":    "tag:tuist-k8s-production",
			"dst":    ["tag:tuist-macmini-production"],
			"deny":   ["root"],
		},
	],

	// Tests run on every save in the console. With the wide-open
	// rule above active, nothing is denied for any source, so these
	// only assert that the explicit env-pair grants parse and
	// accept the intended traffic. Add cross-env deny assertions
	// when the catch-all is removed.
	"tests": [
		{
			"src": "tag:tuist-k8s-staging",
			"accept": [
				"tag:tuist-macmini-staging:8080",
				"tag:tuist-macmini-staging:9091",
				"tag:tuist-macmini-staging:9100",
			],
		},
		{
			"src": "tag:tuist-k8s-canary",
			"accept": [
				"tag:tuist-macmini-canary:8080",
				"tag:tuist-macmini-canary:9091",
				"tag:tuist-macmini-canary:9100",
			],
		},
		{
			"src": "tag:tuist-k8s-production",
			"accept": [
				"tag:tuist-macmini-production:8080",
				"tag:tuist-macmini-production:9091",
				"tag:tuist-macmini-production:9100",
			],
		},
		{
			"src": "tag:tuist-ops",
			"accept": [
				"tag:tuist-macmini-staging:22",
				"tag:tuist-macmini-canary:22",
				"tag:tuist-macmini-production:22",
			],
		},
		// macOS runner-cache path: staging minis reach the staging
		// cluster's Service CIDR on the Kura + DNS ports.
		{
			"src": "tag:tuist-macmini-staging",
			"accept": [
				"10.128.0.10:4000",
				"10.128.0.10:50051",
				"10.128.0.10:53",
			],
		},
		// Note: no test entries with autogroup-based src. Tailscale's
		// test engine doesn't resolve `autogroup:*` as a concrete
		// identity, so the human-kubectl grants above are exercised
		// implicitly via the live access decisions in the console
		// rather than via the test framework.
	],
}
