<?xml version="1.0" encoding="UTF-8"?>
<!--
  Runs the interactive shell bridge independently from dispatch-poll.sh.
  Keeping it as its own LaunchAgent gives launchd direct supervision and
  avoids macOS user-session edge cases where a background child of the
  dispatch loop can disappear while the GitHub runner itself keeps going.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.tuist.runner-shell-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>exec /opt/tuist/runner-shell-agent-supervisor.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/runner</string>

    <key>StandardOutPath</key>
    <string>/var/log/tuist-runner/shell-agent-launchd.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/tuist-runner/shell-agent-launchd.stderr.log</string>

    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
