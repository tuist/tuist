#!/bin/bash
set -euo pipefail

TYPESENSE_API_KEY=$(op read "op://search/TYPESENSE_API_KEY/notesPlain")
CONTAINER_IP=$(ssh root@91.99.179.13 "docker ps --filter label=service=tuist-search --filter label=role=web --format '{{.Names}}' | head -1 | xargs docker inspect --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}'")

scp bin/index-docc.py root@91.99.179.13:/tmp/index-docc.py
ssh root@91.99.179.13 \
  "docker run --rm --network kamal --dns 8.8.8.8 \
    -e TYPESENSE_API_KEY='${TYPESENSE_API_KEY}' \
    -e TYPESENSE_HOST='http://${CONTAINER_IP}:8108' \
    -v /tmp/index-docc.py:/app/index-docc.py:ro \
    python:3.12-slim \
    python3 /app/index-docc.py"
