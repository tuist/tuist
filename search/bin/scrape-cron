#!/bin/bash
# Installs a daily cron job (04:00 UTC) on the remote server that runs all
# indexers: DocSearch scrapers (docs + forum), DocC API indexer, and GitHub
# issues/PRs indexer. Uploads the latest scripts, configs, and secrets to
# /opt/docsearch/ on the server each time it is run.
set -euo pipefail

TYPESENSE_API_KEY=$(op read "op://search/TYPESENSE_API_KEY/notesPlain")
GITHUB_TOKEN=$(op read "op://search/GITHUB_TOKEN/notesPlain" 2>/dev/null || echo "")

SERVER_HOST="91.99.179.13"
SSH_USER="${SEARCH_SSH_USER:-root}"

# Upload configs, scripts, and secrets to server (restricted permissions)
ssh ${SSH_USER}@${SERVER_HOST} "mkdir -p /opt/docsearch && chmod 700 /opt/docsearch"
scp config/docsearch.json ${SSH_USER}@${SERVER_HOST}:/opt/docsearch/docsearch.json
scp config/docsearch-forum.json ${SSH_USER}@${SERVER_HOST}:/opt/docsearch/docsearch-forum.json
scp bin/index-docc ${SSH_USER}@${SERVER_HOST}:/opt/docsearch/index-docc
scp bin/index-github ${SSH_USER}@${SERVER_HOST}:/opt/docsearch/index-github
ssh ${SSH_USER}@${SERVER_HOST} "chmod +x /opt/docsearch/index-docc /opt/docsearch/index-github"
ssh ${SSH_USER}@${SERVER_HOST} "echo '${TYPESENSE_API_KEY}' > /opt/docsearch/.api_key && chmod 600 /opt/docsearch/.api_key"
ssh ${SSH_USER}@${SERVER_HOST} "echo '${GITHUB_TOKEN}' > /opt/docsearch/.github_token && chmod 600 /opt/docsearch/.github_token"

# Create runner script on server
ssh ${SSH_USER}@${SERVER_HOST} "cat > /opt/docsearch/run.sh" << 'REMOTE_SCRIPT'
#!/bin/bash
set -euo pipefail
CONTAINER=$(docker ps --filter label=service=tuist-search --filter label=role=web --format '{{.Names}}' | head -1)
TYPESENSE_API_KEY=$(cat /opt/docsearch/.api_key)
GITHUB_TOKEN=$(cat /opt/docsearch/.github_token 2>/dev/null || echo "")
CONTAINER_IP=$(docker inspect "$CONTAINER" --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}')
TYPESENSE_HOST="http://${CONTAINER_IP}:8108"

# DocSearch scrapers (docs, forum)
for config_file in /opt/docsearch/docsearch*.json; do
  echo "==> Scraping with ${config_file}..."
  CONFIG=$(cat "$config_file")
  docker run --rm --network kamal --dns 8.8.8.8 \
    -e TYPESENSE_API_KEY="$TYPESENSE_API_KEY" \
    -e TYPESENSE_HOST="$CONTAINER" \
    -e TYPESENSE_PORT=8108 \
    -e TYPESENSE_PROTOCOL=http \
    -e CONFIG="$CONFIG" \
    typesense/docsearch-scraper
  echo "==> Done with ${config_file}"
done

# DocC indexer (ProjectDescription API reference)
echo "==> Indexing DocC (ProjectDescription)..."
TYPESENSE_API_KEY="$TYPESENSE_API_KEY" \
TYPESENSE_HOST="$TYPESENSE_HOST" \
  /opt/docsearch/index-docc
echo "==> Done with DocC indexer"

# GitHub indexer (issues and PRs)
echo "==> Indexing GitHub issues and PRs..."
TYPESENSE_API_KEY="$TYPESENSE_API_KEY" \
TYPESENSE_HOST="$TYPESENSE_HOST" \
GITHUB_TOKEN="$GITHUB_TOKEN" \
  /opt/docsearch/index-github
echo "==> Done with GitHub indexer"
REMOTE_SCRIPT
ssh ${SSH_USER}@${SERVER_HOST} "chmod 700 /opt/docsearch/run.sh"

# Install systemd service and timer
ssh ${SSH_USER}@${SERVER_HOST} "cat > /etc/systemd/system/docsearch-scraper.service" << 'SERVICE'
[Unit]
Description=DocSearch scraper and search indexer
After=docker.service

[Service]
Type=oneshot
ExecStart=/opt/docsearch/run.sh
SERVICE

ssh ${SSH_USER}@${SERVER_HOST} "cat > /etc/systemd/system/docsearch-scraper.timer" << 'TIMER'
[Unit]
Description=Run DocSearch scraper daily at 04:00 UTC

[Timer]
OnCalendar=*-*-* 04:00:00 UTC
Persistent=true

[Install]
WantedBy=timers.target
TIMER

ssh ${SSH_USER}@${SERVER_HOST} "systemctl daemon-reload && systemctl enable --now docsearch-scraper.timer"

# Remove old cron job if present
ssh ${SSH_USER}@${SERVER_HOST} "rm -f /etc/cron.d/docsearch-scraper"

echo "Systemd timer installed — scraper will run daily at 04:00 UTC"
echo "View logs: ssh ${SSH_USER}@${SERVER_HOST} journalctl -u docsearch-scraper"
